{
  "name": "jacob-ramirez-portfolio",
  "version": "1.0.0",
  "scripts": {
    "start": "eleventy --serve",
    "build:css": "npx postcss \"static/css/*.css\" --use autoprefixer -d static/css --verbose",
    "build": "npm run build:css && eleventy --output=public",
    "dev": "eleventy --serve",
    "postinstall": "npm install -g @11ty/eleventy"
  },
  "devDependencies": {
    "@11ty/eleventy": "^2.0.0",
    "autoprefixer": "^10.4.21",
    "postcss-cli": "^11.0.1"
  }
}
