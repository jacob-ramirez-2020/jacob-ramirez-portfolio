{
  "name": "jacob-ramirez-portfolio",
  "version": "1.0.0",
  "scripts": {
  "build": "eleventy --output=public",
  "start": "eleventy --serve",
  "dev":   "eleventy --serve",
  "check:links": "linkinator ./public --recursive --silent",
  "postinstall": "npm install -g @11ty/eleventy"
},

  
  "dependencies": {
    "postcss-cli":   "^11.0.1",
    "autoprefixer":  "^10.4.21"
  },
  
  "devDependencies": {
    "@11ty/eleventy": "^2.0.0",
    "@tailwindcss/postcss": "^4.1.4",
    "linkinator": "^6.1.2",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.4"
  }
}
